#!/usr/bin/env python3
"""Turn chapters/*.md into a manual in site/.

No framework, no server, no build step beyond this file. Run ./build and open
site/index.html — it works off the filesystem as happily as off a web server,
which is the whole point: a manual you can't read without infrastructure is a
manual you won't read.

The look is not chosen so much as inherited. The manual wears orchard's own
themes: dark is catppuccin-frappe, light is rose-pine-dawn, and both palettes are
lifted straight from the theme files in the repo next door. The toggle isn't a
generic sun and moon — it names the theme you're in, because on the desktop
those are real things you can switch to.
"""
import json
import re
import shutil
from pathlib import Path

import markdown

HERE = Path(__file__).parent
CHAPTERS = HERE / "chapters"
SITE = HERE / "site"

# Straight out of ~/code/orchard/configuration/desktop/themes/config/orchard-themes/.
THEMES = {
    "catppuccin-frappe": {
        "bg": "#303446", "raised": "#414559", "line": "#51576d",
        "fg": "#c6d0f5", "muted": "#a5adce", "accent": "#8caaee", "quiet": "#81c8be",
    },
    "rose-pine-dawn": {
        "bg": "#faf4ed", "raised": "#fffaf3", "line": "#dfdad9",
        "fg": "#575279", "muted": "#9893a5", "accent": "#907aa9", "quiet": "#286983",
    },
}

# A <code> span that is really a key you press, not a word you read.
KEYS = r"Cmd|Ctrl|Shift|Option|Fn|Return|Escape|Esc|Tab|Delete|Space|F\d{1,2}|Left|Right|Up|Down"
CHORD = re.compile(rf"<code>((?:{KEYS}|[A-Za-z0-9,\[\]`])(?:\+(?:{KEYS}|[A-Za-z0-9,\[\]`]))+)</code>")
LONE_KEY = re.compile(rf"<code>({KEYS})</code>")


def as_keycaps(html):
    """Render key chords as keys. The manual is for a keyboard-driven desktop;
    a hotkey should look like the thing your hands do, not like a filename."""
    def caps(match):
        keys = "".join(f"<kbd>{k}</kbd>" for k in match.group(1).split("+"))
        return f'<span class="chord">{keys}</span>'
    html = CHORD.sub(caps, html)
    return LONE_KEY.sub(lambda m: f'<span class="chord"><kbd>{m.group(1)}</kbd></span>', html)


def read_chapters():
    chapters = []
    for path in sorted(CHAPTERS.glob("*.md")):
        raw = path.read_text()
        title = raw.splitlines()[0].lstrip("# ").strip()
        body = "\n".join(raw.splitlines()[1:]).strip()
        chapters.append({
            "slug": re.sub(r"^\d+-", "", path.stem),
            "title": title,
            "markdown": body,
        })
    return chapters


def render(chapters):
    converter = markdown.Markdown(extensions=["tables", "fenced_code", "attr_list"])
    for chapter in chapters:
        converter.reset()
        chapter["html"] = as_keycaps(converter.convert(chapter["markdown"]))
        # what search matches on: the prose, minus the markup
        chapter["text"] = re.sub(r"<[^>]+>", " ", chapter["html"])
        chapter["text"] = re.sub(r"\s+", " ", chapter["text"]).strip()
    return chapters


def contents(chapters, here):
    links = []
    for chapter in chapters:
        current = ' aria-current="page"' if chapter["slug"] == here else ""
        links.append(
            f'<li><a href="{chapter["slug"]}.html"{current}>{chapter["title"]}</a></li>'
        )
    return "\n".join(links)


def page(chapter, chapters):
    return TEMPLATE.format(
        title=chapter["title"],
        contents=contents(chapters, chapter["slug"]),
        body=chapter["html"],
    )


TEMPLATE = """<!doctype html>
<html lang="en" data-theme="catppuccin-frappe">
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{title} — the orchard manual</title>
<link rel="icon" href="orchard.png">
<link rel="stylesheet" href="manual.css">
<body>
<a class="skip" href="#chapter">Skip to the chapter</a>

<header class="top">
  <a class="mark" href="welcome.html">
    <img src="orchard.png" alt="" width="22" height="22">
    <span>orchard</span>
  </a>
  <form class="find" role="search" onsubmit="return false">
    <input id="find" type="search" placeholder="Search the manual" autocomplete="off"
           aria-label="Search the manual">
    <kbd class="hint">/</kbd>
  </form>
  <button id="theme" class="theme" type="button" aria-live="polite"></button>
</header>

<div class="shell">
  <nav class="contents" aria-label="Contents">
    <p class="eyebrow">Contents</p>
    <ol>
      {contents}
    </ol>
  </nav>

  <main id="chapter">
    <h1>{title}</h1>
    {body}
  </main>
</div>

<div id="results" class="results" hidden>
  <ul id="hits"></ul>
  <p id="nothing" class="nothing" hidden></p>
</div>

<script src="search.js"></script>
<script src="manual.js"></script>
</body>
</html>
"""


def stylesheet():
    def variables(theme, colours):
        body = "\n".join(f"  --{name}: {value};" for name, value in colours.items())
        return f'[data-theme="{theme}"] {{\n{body}\n}}'

    themes = "\n\n".join(variables(name, colours) for name, colours in THEMES.items())
    return CSS.replace("/*THEMES*/", themes)


CSS = """
@font-face { font-family: Quattro; src: url(fonts/quattro-regular.woff2) format("woff2");
             font-weight: 400; font-style: normal; font-display: swap; }
@font-face { font-family: Quattro; src: url(fonts/quattro-bold.woff2) format("woff2");
             font-weight: 700; font-style: normal; font-display: swap; }
@font-face { font-family: Quattro; src: url(fonts/quattro-italic.woff2) format("woff2");
             font-weight: 400; font-style: italic; font-display: swap; }
@font-face { font-family: WriterMono; src: url(fonts/mono-regular.woff2) format("woff2");
             font-weight: 400; font-display: swap; }
@font-face { font-family: WriterMono; src: url(fonts/mono-bold.woff2) format("woff2");
             font-weight: 700; font-display: swap; }

/* The manual wears orchard's own themes. These are the real palettes, lifted from
   the theme folders in the repo — not a light/dark pair invented for a website. */
/*THEMES*/

